# ─── Provider Strategy ──────────────────────────────────────────────────────────
# Opciones:
#   single     — un solo provider fijo (default)
#   fallback   — primario con fallback automático si falla
#   roundrobin — alterna entre primario y secundario por mensaje
#   combined   — roundrobin + fallback si el elegido falla
#
# Se puede cambiar en runtime con: !provider combined
# El archivo provider.state.json tiene prioridad sobre estas variables.
PROVIDER_STRATEGY=single

# Provider primario
LLM_PROVIDER=groq
# Provider secundario (para fallback y round-robin)
LLM_PROVIDER_SECONDARY=openrouter

# ─── Groq ──────────────────────────────────────────────────────────────────────
# Gratis en: https://console.groq.com
# Modelos gratuitos recomendados:
#   llama-3.3-70b-versatile   (mejor calidad, 6k req/día)
#   llama-3.1-8b-instant      (más rápido)
#   gemma2-9b-it              (liviano)
#   qwen-qwq-32b              (razonamiento avanzado)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenRouter ────────────────────────────────────────────────────────────────
# API key: https://openrouter.ai/keys
# Modelos gratuitos (suffix :free):
#   meta-llama/llama-3.3-70b-instruct:free   (default gratis)
#   google/gemini-2.0-flash-exp:free
#   deepseek/deepseek-chat:free
#   mistralai/mistral-7b-instruct:free
# Modelos de pago:
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o
#   google/gemini-2.0-flash
#   deepseek/deepseek-r1
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=WhatsApp Agent Termux

# ─── Ollama (local ARM64 en Termux) ────────────────────────────────────────────
# Instalar: pkg install ollama && ollama pull qwen2.5:1.5b
# Modelos por RAM disponible:
#   qwen2.5:1.5b   ~1GB   (mínimo, phones 4GB)
#   qwen2.5:3b     ~2GB   (buena calidad)
#   llama3.2:3b    ~2GB   (alternativa Meta)
#   gemma3:4b      ~3GB   (excelente, phones 6GB+)
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen2.5:1.5b

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
GATEWAY_PORT=3000
DASHBOARD_PORT=3001

# ─── Mastra ────────────────────────────────────────────────────────────────────
MASTRA_DB_PATH=./data/mastra.db
